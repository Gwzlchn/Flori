{
	# 自签场景:无 SNI(按 IP 访问)时也给出证书
	default_sni {$EDGE_HOST}
	# 不绑 80(对外只 443+22),禁用 HTTP->HTTPS 自动跳转
	auto_https disable_redirects
}

https://{$EDGE_HOST}, https://localhost, https://127.0.0.1 {
	tls internal

	# MCP(streamable-http):把知识库作为 MCP 提供给 agent。自身 Bearer token 鉴权由
	# NAS mcp-http 强制(FLORI_MCP_TOKEN);放行 Basic(MCP client 用 Bearer,与 Basic 同头冲突)。
	# 经反向 SSH 隧道口 127.0.0.1:8091 → NAS mcp-http:8090。
	# 注:必须用独立 handle 块(而非给 @protected 加 not path);单个 not path 多模式只认第一个。
	handle /mcp* {
		reverse_proxy 127.0.0.1:8091
	}

	# /api/runner/* 是 worker↔网关的机机接口,自带 Bearer 鉴权(注册 token + 每 worker token),
	# 且 worker 只发 Authorization: Bearer——与 Basic 同头冲突,故须放行不挂 Basic。
	handle /api/runner/* {
		reverse_proxy 127.0.0.1:8000
	}

	# 其余人面入口(SPA + /api/* 非 runner):一道门 Basic Auth,再按路径路由。
	handle {
		basic_auth {
			flori {$FLORI_BASIC_HASH}
		}

		# /api/* 反代到 NAS api(反向 SSH 隧道口)。
		handle /api/* {
			reverse_proxy 127.0.0.1:8000
		}

		# 前端:反代到本机 flori-frontend 容器(ghcr 镜像,Watchtower 跟 CI 自动更新)。
		handle {
			reverse_proxy 127.0.0.1:8090
		}
	}
}
