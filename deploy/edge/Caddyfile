{
	# 无 SNI 或按 IP 访问时给出 IP 站点的 internal 证书。
	default_sni {$EDGE_HOST}
	# 不绑 80(对外只 443+22),禁用 HTTP->HTTPS 自动跳转。
	auto_https disable_redirects
}

(common) {
	# MCP(streamable-http):自身 Bearer token 鉴权由 NAS mcp-http 强制。
	# 放行 Basic(MCP client 用 Bearer,与 Basic 同头冲突)。经反向 SSH 隧道口 8091 到 NAS mcp-http。
	handle /mcp* {
		reverse_proxy localhost:8091
	}

	# /api/runner/* 是 worker 网关机机接口,自带 Bearer 鉴权,放行 Basic。
	handle /api/runner/* {
		reverse_proxy localhost:8000 {
			health_uri /api/health/live
			health_interval 10s
		}
	}

	# 其余人面入口(SPA + /api/* 非 runner):一道门 Basic Auth,再按路径路由。
	handle {
		basic_auth {
			flori {$FLORI_BASIC_HASH}
		}

		# /api/* 反代到 NAS api(反向 SSH 隧道口)。
		handle /api/* {
			reverse_proxy localhost:8000 {
				health_uri /api/health/live
				health_interval 10s
			}
		}

		# 前端:反代到本机 flori-frontend 容器。
		handle {
			reverse_proxy localhost:8090
		}
	}
}

https://{$EDGE_DOMAIN} {
	tls /etc/caddy/certs/{$EDGE_DOMAIN}.fullchain.pem /etc/caddy/certs/{$EDGE_DOMAIN}.key
	import common
}

https://{$EDGE_HOST}, https://localhost, https://127.0.0.1 {
	tls internal
	import common
}
