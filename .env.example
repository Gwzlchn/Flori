# 复制为 .env 后填写。挂公网前务必设强随机 API_TOKEN。

# 访问鉴权
API_TOKEN=                      # 访问令牌;挂公网必设强随机串,留空=不鉴权(仅限本地)
API_BIND_IP=127.0.0.1           # API 端口绑定地址;默认仅本机(经 Caddy/Tunnel 暴露),局域网直连设局域网 IP 并务必设 API_TOKEN
FLORI_MCP_TOKEN=                # MCP(HTTP)Bearer 令牌;挂公网必设强随机串。留空且下项≠1 时 MCP-http fail-closed(503)
FLORI_MCP_ALLOW_NO_AUTH=0       # 仅可信内网且 FLORI_MCP_TOKEN 留空时设 1 放行 MCP(公网务必保持 0 并设 token)
MCP_BIND_IP=127.0.0.1           # mcp-http 端口绑定地址;默认仅本机(经 Caddy/Tunnel 暴露)
MCP_PORT=8090                   # mcp-http 宿主端口;API 的本地 MCP 接入 URL 使用这个端口
FLORI_MCP_ALLOWED_HOSTS=        # 经反代/隧道暴露时放行的 Host(逗号分隔,如 <edge-host>,localhost,127.0.0.1);否则公网域名会被 DNS-rebinding 保护判 421。"*"/留空=关该保护
FLORI_MCP_RATE_LIMIT=120        # MCP-http 进程内全局限流(请求/分钟),超限→429;0/留空=关闭(留空时按默认 120)

# AI Provider(至少配一个;或设 DRY_RUN=1 空跑不调真实 API)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
OPENAI_API_KEY=

# 可选
DRY_RUN=0                       # 1 = AI 步骤不调真实 API(点通流程用)
HTTPS_PROXY=                    # 访问外部 API 的代理,不需要可留空
# 注意:不要填宿主回环代理(如 http://127.0.0.1:7890)——容器内 127.0.0.1 指向容器自身,
# 会导致 AI API/下载全部失败。要用代理请填宿主局域网 IP,并按需设 NO_PROXY。
# NO_PROXY=redis,minio,localhost,127.0.0.1  # 内部服务不走代理
# REGISTRATION_TOKEN_TTL_SEC=86400  # 铸造的接入 token 有效期(秒),默认 24h,泄漏自动失效

# 部署(主机相关,按自己环境填)
FLORI_DATA_DIR=                 # 数据/产物挂载目录;留空=命名卷(prod)/./data(dev),用独立磁盘填绝对路径
FLORI_DEPLOYMENT_ID=            # 非密钥;首次部署生成一次稳定ID,exact DR与线上恢复必须一致
FLORI_CONTENT_REPOSITORY_DIR=.local/content-repository # 便携CAS仓库宿主路径;生产应设到独立盘并另做第二份物理副本
FLORI_DR_BACKUP_DIR=.local/exact-dr # exact DR三件套宿主目录;生产建议放NAS灾备目录
FLORI_EXACT_DR_DRAIN_TIMEOUT_SEC=3600 # 等待全部Worker完成当前步骤的最长秒数;超时不创建归档
FLORI_DR_OWNER_UID=              # 可选:三件套宿主owner UID;与GID必须同时设置
FLORI_DR_OWNER_GID=              # 可选:三件套宿主owner GID;与UID必须同时设置
FLORI_INBOX_DIR=.local/inbox    # local_dir 订阅监听目录(宿主侧,默认 .local/inbox=gitignored 本地区),挂到容器 /data/inbox;订阅 source_id 填 /data/inbox
                                # 生产设到数据盘(与 FLORI_DATA_DIR 同源,如 /volume2/DATA/flori/inbox)——运行时数据永不放仓库树
FLORI_SOURCE_LIBRARY_ENABLED=0  # 1=启用受控NAS大视频源引用;同时用 --profile source-library 启动专用Worker
FLORI_SOURCE_LIBRARY_ROOT_ID=library # API/DB中的稳定根ID,只用小写字母、数字、_-;不包含宿主路径
FLORI_SOURCE_LIBRARY_DIR=       # 宿主NAS源库绝对路径;仅以ro挂到API/worker-source,不写入DB或任务载荷
API_PORT=8000                   # 宿主暴露的 API 端口
DOZZLE_BIND_IP=127.0.0.1        # Dozzle 绑定地址;局域网访问设为局域网 IP
DOZZLE_PORT=8888                # Dozzle 端口
DOZZLE_REMOTE_AGENT=            # 可选:远程 dozzle agent(host:port,如经 SSH 隧道),留空=不接入
FRONTEND_PORT=8080              # allinone 模式前端端口
FLORI_DISK_MIN_FREE_GB=5        # readiness 数据盘最少可用 GB;同时还需满足下方百分比
FLORI_DISK_MIN_FREE_PCT=5       # readiness 数据盘最少可用百分比
FLORI_READINESS_PROBE_TTL_SEC=5 # SQLite/MinIO 写探针短缓存;过期不复用陈旧绿灯
FLORI_READINESS_PROBE_TIMEOUT_SEC=3 # 单次写探针超时;失败即 fail-closed
FLORI_STEP_LOG_MAX_BYTES=10485760 # 单步骤日志硬上限,超出后原子保留尾部;默认 10MiB
FLORI_DOCKER_CONTROL_TIMEOUT_SEC=5 # 动态步骤容器 kill/wait/log/remove 控制面收尾上限

# 分布式 worker(可选,远程机器接活才需要)
# 设了 MINIO_URL 即从本地存储切到对象存储(api/scheduler/所有 worker 必须一致);
# 启动时带 --profile distributed 以拉起 minio。留空=单机本地存储。
MINIO_URL=                       # 如 minio:9000(本机服务);远程 worker 经隧道指向 127.0.0.1:9000
MINIO_ACCESS_KEY=                # MinIO 账号
MINIO_SECRET_KEY=                # MinIO 密钥(>=8 位)
MINIO_BUCKET=flori
MINIO_DATA_DIR=                  # MinIO 对象落盘目录;留空=命名卷,放独立磁盘填绝对路径
WORK_DIR=/tmp/flori-work         # 远程 worker 拉取产物的本机临时目录

# 构建(一般不用改)
# USE_USTC_MIRROR=1             # 1=USTC 源(国内快),0=官方源(海外/CI)
# IMAGE_OWNER=                  # ghcr 镜像归属(ghcr.io/<owner>/flori*);fork 后改成自己的用户名

# 边缘机(ECS):反向 SSH 隧道目标。域名可信证书由 deploy/edge/.env 的 EDGE_DOMAIN 单独配置。
# 前端镜像走 ghcr/Watchtower 全自动 CD,无需从 NAS 手动直推。
EDGE_HOST=                      # 边缘机主机(IP),留空=不启用边缘/隧道
