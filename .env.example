# 复制为 .env 后填写。挂公网前务必设强随机 API_TOKEN。

# === 访问鉴权 ===
API_TOKEN=                      # 访问令牌；挂公网必设强随机串，留空=不鉴权（仅限本地）

# === AI Provider（至少配一个；或设 DRY_RUN=1 空跑不调真实 API）===
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
OPENAI_API_KEY=

# === 可选 ===
DRY_RUN=0                       # 1 = AI 步骤不调真实 API（点通流程用）
HTTPS_PROXY=                    # 访问外部 API 的代理，不需要可留空

# === 构建/部署（一般不用改）===
# USE_USTC_MIRROR=1             # 1=USTC 源（国内快），0=官方源（海外/CI）
